{
  "name": "pi-mimir",
  "version": "0.1.0",
  "license": "MIT",
  "description": "OpenSpec-driven development workflow for Pi Agent",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "main": "index.js",
