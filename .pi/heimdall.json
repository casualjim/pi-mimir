{
  "sandbox": {
    "enabled": true,
    "network": "host",
    "env": {
      "deny": [
        "*_TOKEN",
        "*_SECRET",
        "*_PASSWORD",
        "*_KEY"
      ]
    },
    "filesystem": {
      "deny": [
        "~/Private",
        "~/.ssh",
        "~/.config",
        "~/.aws"
      ],
      "writable": [
        "~/github",
        "~/.npm",
        "~/.local/state/mise",
        "~/.local/share/mise",
        "~/.cache/mise",
        "~/.cache/lindera",
        "~/.cache/syntastica-parsers",
        "~/.cache/huggingface",
        "~/.local/state/hk"
      ]
    }
  },
  "commandPolicies": [
    {
      "name": "no-cargo-test",
      "blocked": [
        "cargo",
        "test"
      ],
      "message": "Use `mise test` or `mise run test` instead of `cargo test`."
    },
    {
      "name": "no-cargo-nextest",
      "blocked": [
        "cargo",
        "nextest"
      ],
      "message": "Use `mise test` or `mise run --force test` instead of `cargo nextest`."
    }
  ]
}
